{
  "name": "pricy",
  "private": true,
  "scripts": {
    "build": "node build.js",
    "test": "node build.js && node --test test/*.test.js",
    "test:e2e": "node build.js && playwright test",
    "test:crawlers": "node --test test/live-crawl.mjs",
    "dev": "node build.js && wrangler dev --persist-to \"${TMPDIR:-/tmp}/pricy-wrangler-state\"",
    "deploy": "node build.js && wrangler deploy"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "wrangler": "^4.0.0"
  }
}
