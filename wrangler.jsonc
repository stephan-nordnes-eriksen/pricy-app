{
  "name": "pricy",
  "compatibility_date": "2026-07-13",
  "main": "worker/index.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    // MCP OAuth surface: discovery, DCR, login page, token exchange must
    // reach the worker — the SPA fallback answering 200+HTML there breaks
    // claude.ai's connector flow. CAUTION: setting run_worker_first AT ALL
    // makes the asset layer claim every path NOT listed (it answered /api/*
    // POSTs with 405, taking down login) — /api/* must stay in this list.
    "run_worker_first": ["/api/*", "/img/*", "/.well-known/*", "/authorize", "/token", "/register", "/mcp"]
  },
  "r2_buckets": [
    {
      // product images, keyed products/<id>, written by ingest's syncImages,
      // served at GET /img/<id>
      "binding": "IMAGES",
      "bucket_name": "pricy-images"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      // NOT the account's "pricy" D1 — that one belongs to the other
      // (live pricy.no) project despite the name
      "database_name": "pricy-app",
      "database_id": "ae84c6cb-b7f8-4025-b7a8-7bfb1f9f8dc1"
    }
  ],
  "routes": [
    { "pattern": "pricy.no", "custom_domain": true },
    // www 301s to apex in the fetch handler — keeps the session cookie on one host
    { "pattern": "www.pricy.no", "custom_domain": true }
  ],
  // hourly offer refresh (worker scheduled handler); price_points stay
  // one-per-day via the upsert
  "triggers": { "crons": ["0 * * * *"] },
  // Auto-promotion category map (OPEN-CATALOG-PLAN B): per-shop raw source
  // category → prototype category. A hidden discovered product goes live when
  // a source supplies name + brand + a category mapped here; unmapped
  // categories stay hidden (that IS the junk filter — never map accessory
  // categories). Grow by hand as feeds reveal their vocabularies, e.g.
  // "CATMAP": { "Komplett": { "Mobiltelefoner": "Phones" } }
  // Vocabulary observed 2026-07-22 from breadcrumb srcCats (Power, NetOnNet
  // scrapes). Deliberately unmapped: accessories, smartwatches (no category
  // for them), refurbished/outlet, generic parents ("Mobil og Smartklokker"),
  // PC components — unmapped stays hidden, that IS the junk filter.
  "vars": { "CATMAP": {
    "Power": {
      "Mobiltelefon": "Phones",
      "TV": "TV",
      "True wireless hodetelefoner": "Audio",
      "Trådløse hodetelefoner": "Audio",
      "Hodetelefoner med ledning": "Audio",
      "Open-ear hodetelefoner": "Audio",
      "Benledende hodetelefoner": "Audio",
      "Ørepropper": "Audio",
      "Lydplanker": "Audio",
      "Smarthøyttaler": "Audio",
      "Trådløs støvsuger": "Home",
      "Robotstøvsuger": "Home",
      "Smarte lightstrips": "Home",
      "Kaffetrakter": "Kitchen",
      "Airfryers": "Kitchen",
      "Frityrkoker": "Kitchen",
      "Playstation-konsoll": "Gaming",
      "Xbox-konsoll": "Gaming",
      "Nintendo-konsoll": "Gaming",
      "Playstation-kontrollere": "Gaming",
      "Nintendo-kontrollere": "Gaming",
      "Xbox-spill": "Gaming",
      "Nettbrett": "Computers",
      "Lesebrett": "E-readers"
    },
    "CDON": {
      "OLED TV": "TV",
      "Airfryere": "Kitchen",
      "Over-ear hodetelefoner": "Audio",
      "True Wireless med ANC": "Audio",
      "Støvsugere": "Home",
      "Smarte lamper": "Home",
      "Håndkontroller": "Gaming",
      "Lesebrett": "E-readers"
    },
    "NetOnNet": {
      "iPhone": "Phones",
      "Samsung mobiltelefon": "Phones",
      "Xiaomi mobiltelefon": "Phones",
      "Google Pixel": "Phones",
      "Nothing mobiltelefon": "Phones",
      "Motorola mobiltelefon": "Phones",
      "Doro mobiltelefon": "Phones",
      "Mobiltelefoner": "Phones",
      "In-ear-hodetelefoner": "Audio",
      "Over-ear-hodetelefoner": "Audio",
      "Hodetelefoner": "Audio",
      "Trådløse hodetelefoner": "Audio",
      "Hodetelefoner til trening": "Audio",
      "Bluetooth-høyttalere": "Audio",
      "Partyhøyttalere": "Audio",
      "Smarthøyttalere": "Audio",
      "Soundbarer": "Audio",
      "22–45 tommer": "TV",
      "56–70 tommer": "TV",
      "75 tommer og større": "TV",
      "Projektorer": "Projectors",
      // media players/TV sticks are not TVs; Home = smart-home gadgets
      "Mediaspillere": "Home",
      "Google Chromecast": "Home",
      "Nettbrett": "Computers",
      "iPad": "Computers",
      "MacBook": "Computers",
      "Laptoper": "Computers",
      "Laptoper 12 - 14 tommer": "Computers",
      "Laptoper 15 - 16 tommer": "Computers",
      "Chromebooks": "Computers",
      "Gamingskjermer 31–57 tommer": "Computers",
      "Espressomaskiner": "Kitchen",
      "Kaffetraktere": "Kitchen",
      "Kaffemaskiner og kaffe": "Kitchen",
      "Nintendo-konsoller": "Gaming",
      "PlayStation-konsoll": "Gaming",
      "PlayStation": "Gaming",
      "Xbox": "Gaming",
      "Trådløs støvsuger": "Home",
      "Grovstøvsuger": "Home",
      "Selvtømmende robotstøvsugere": "Home",
      "Dampvasker": "Home",
      "Smartlåser": "Home",
      "Philips Hue": "Home",
      "Lego Icons": "Toys",
      "LEGO for voksne 18 år": "Toys",
      "Lesebrett": "E-readers"
    }
  } }
  // Feature flag for real magic-link mail: the worker sends via
  // env.SEND_EMAIL when bound, console.logs the link when not. Email
  // Sending needs the Workers paid plan — once upgraded, onboard pricy.no
  // (dashboard: Email Service → Email Sending → Onboard Domain, adds
  // SPF/DKIM/DMARC), then uncomment and deploy:
  // "send_email": [{ "name": "SEND_EMAIL" }]
}
